# Local development streams videos from D:\_content_library through /api/videos/[id].
# For Vercel, upload MP4s to object storage and set a public CDN base URL.
# Example: https://media.tudominio.com
NEXT_PUBLIC_VIDEO_BASE_URL=

# Puerta de acceso: si se define, la app pide esta palabra de paso.
ACCESS_CODE=

# Ediciones compartidas en la nube (Cloudflare D1).
# Enciende el modo nube en el cliente (fetch a las API de edits/history/revert).
NEXT_PUBLIC_CLOUD_EDITS=
# Credenciales del REST de Cloudflare D1 (solo servidor).
CF_ACCOUNT_ID=a55510681b436c417cb38b942b1717de
CF_D1_DATABASE_ID=
CF_API_TOKEN=
